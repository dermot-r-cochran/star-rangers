<!DOCTYPE html>
<html lang="{{ site.language | default('en') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description | default(site.description) }}" />
  <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <link rel="stylesheet" href="/star-rangers/css/main.css" />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="site-header" role="banner">
    <div class="site-header__inner">
      <a class="site-logo" href="/star-rangers/">
        <span class="site-logo__icon" aria-hidden="true">✦</span>
        <span class="site-logo__text">{{ site.name }}</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list" role="list">
          <li><a href="/star-rangers/" {% if page.url == "/star-rangers/" %}aria-current="page"{% endif %}>Home</a></li>
          <li><a href="/star-rangers/seasons/" {% if "/seasons/" in page.url %}aria-current="page"{% endif %}>Seasons</a></li>
          <li><a href="/star-rangers/threads/" {% if "/threads/" in page.url %}aria-current="page"{% endif %}>Threads</a></li>
          <li><a href="/star-rangers/characters/" {% if "/characters/" in page.url %}aria-current="page"{% endif %}>Characters</a></li>
          <li><a href="/star-rangers/timeline/" {% if "/timeline/" in page.url %}aria-current="page"{% endif %}>Timeline</a></li>
          <li><a href="/star-rangers/lore/" {% if "/lore/" in page.url %}aria-current="page"{% endif %}>Lore</a></li>
          <li><a href="/star-rangers/atlas/" {% if "/atlas/" in page.url %}aria-current="page"{% endif %}>Atlas</a></li>
          <li><a href="/star-rangers/glossary/" {% if "/glossary/" in page.url %}aria-current="page"{% endif %}>Glossary</a></li>
          <li><a href="/star-rangers/codex/" {% if "/codex/" in page.url %}aria-current="page"{% endif %}>Codex</a></li>
          <li><a href="/star-rangers/about/" {% if "/about/" in page.url %}aria-current="page"{% endif %}>About</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content" class="main-content">
    {{ content | safe }}

    {% if comments %}
    {% set commentsCategoryConfig = giscus.categories[commentsCategory] %}
    <section class="site-comments" aria-label="Comments">
      <h2 class="site-comments__heading">Discussion</h2>
      <script src="https://giscus.app/client.js"
        data-repo="{{ giscus.repo }}"
        data-repo-id="{{ giscus.repoId }}"
        data-category="{{ commentsCategoryConfig.name }}"
        data-category-id="{{ commentsCategoryConfig.id }}"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="dark"
        data-lang="en"
        crossorigin="anonymous"
        async>
      </script>
    </section>
    {% endif %}
  </main>

  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      {% if theme == "fellowship" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Orchestral fantasy</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/fellowship-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% elif theme == "starquest" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Sci-fi ambient</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/starquest-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% elif theme == "pets" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Playful ukulele</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/pets-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% else %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Celtic ambient</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/celtic-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% endif %}
      <p>
        <span>{{ site.name }}</span> — Interactive Fiction.
        Copyright © {{ build.copyrightYears }} Dermot R. Cochran.
        Released under the <a href="/star-rangers/#license" rel="license">CC BY-NC-ND 4.0</a> licence.
      </p>
    </div>
  </footer>

  <script src="/star-rangers/js/pov.js" defer></script>
</body>
</html>
