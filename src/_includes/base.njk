<!DOCTYPE html>
<html lang="{{ site.language | default('en') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description | default(site.description) }}" />
  <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <link rel="stylesheet" href="/star-rangers/css/main.css?v={{ build.assetVersion }}" />
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} — New Episodes" href="{{ '/feed/feed.xml' | absoluteUrl(site.url) }}" />

  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:type" content="{{ ogType }}" />
  <meta property="og:title" content="{{ title | default(site.title) }}" />
  <meta property="og:description" content="{{ description | default(site.description) }}" />
  <meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}" />
  <meta property="og:image" content="{{ ogImage | absoluteUrl(site.url) }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title | default(site.title) }}" />
  <meta name="twitter:description" content="{{ description | default(site.description) }}" />
  <meta name="twitter:image" content="{{ ogImage | absoluteUrl(site.url) }}" />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="site-header" role="banner">
    <div class="site-header__inner">
      <a class="site-logo" href="/star-rangers/">
        <span class="site-logo__icon" aria-hidden="true">✦</span>
        <span class="site-logo__text">{{ site.name }}</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list" role="list">
          <li><a href="/star-rangers/" {% if page.url == "/star-rangers/" %}aria-current="page"{% endif %}>Home</a></li>
          <li><a href="/star-rangers/seasons/" {% if "/seasons/" in page.url %}aria-current="page"{% endif %}>Seasons</a></li>
          <li><a href="/star-rangers/threads/" {% if "/threads/" in page.url %}aria-current="page"{% endif %}>Threads</a></li>
          <li><a href="/star-rangers/characters/" {% if "/characters/" in page.url %}aria-current="page"{% endif %}>Characters</a></li>
          <li><a href="/star-rangers/timeline/" {% if "/timeline/" in page.url %}aria-current="page"{% endif %}>Timeline</a></li>
          <li><a href="/star-rangers/lore/" {% if "/lore/" in page.url %}aria-current="page"{% endif %}>Lore</a></li>
          <li><a href="/star-rangers/atlas/" {% if "/atlas/" in page.url %}aria-current="page"{% endif %}>Atlas</a></li>
          <li><a href="/star-rangers/glossary/" {% if "/glossary/" in page.url %}aria-current="page"{% endif %}>Glossary</a></li>
          <li><a href="/star-rangers/codex/" {% if "/codex/" in page.url %}aria-current="page"{% endif %}>Codex</a></li>
          <li><a href="/star-rangers/journal/" {% if "/journal/" in page.url %}aria-current="page"{% endif %}>Journal</a></li>
          <li><a href="/star-rangers/about/" {% if "/about/" in page.url %}aria-current="page"{% endif %}>About</a></li>
        </ul>
      </nav>
      <div class="site-search" data-pagefind-bundle="/star-rangers/pagefind/" data-pagefind-ignore>
        <form class="site-search__form" role="search" aria-label="Search the site">
          <input
            type="search"
            class="site-search__input"
            id="site-search-input"
            placeholder="Search…"
            autocomplete="off"
            aria-expanded="false"
            aria-controls="site-search-results"
          />
        </form>
        <div class="site-search__results" id="site-search-results" hidden></div>
      </div>
    </div>
  </header>

  <main id="main-content" class="main-content" data-pagefind-body>
    {{ content | safe }}

    {% if comments and commentsEnabled %}
    {% set commentsCategoryConfig = giscus.categories[commentsCategory] %}
    <section class="site-comments" aria-label="Comments" data-pagefind-ignore>
      <h2 class="site-comments__heading">Discussion</h2>
      <script src="https://giscus.app/client.js"
        data-repo="{{ giscus.repo }}"
        data-repo-id="{{ giscus.repoId }}"
        data-category="{{ commentsCategoryConfig.name }}"
        data-category-id="{{ commentsCategoryConfig.id }}"
        {% if comment_id %}
        data-mapping="specific"
        data-term="{{ comment_id }}"
        {% else %}
        data-mapping="pathname"
        {% endif %}
        {# Exact-title match, not a loose/substring search: without this, a
           chapter's own comment_id (e.g. "unauthorised-therefore") could
           loosely match a scene's, which is that same term plus a suffix
           (e.g. "unauthorised-therefore-scene-1-adaeze") - pulling in the
           wrong discussion instead of showing "no comments yet." Also what
           makes a stale comment_id (e.g. a deleted chapter's) fail
           gracefully: with no exact-title discussion to find, giscus just
           shows an empty thread rather than guessing at a near match. #}
        data-strict="1"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="dark"
        data-lang="en"
        crossorigin="anonymous"
        async>
      </script>
    </section>
    {% endif %}
  </main>

  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      {% if theme == "fellowship" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Orchestral fantasy</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/fellowship-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% elif theme == "starquest" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Sci-fi ambient</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/starquest-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% elif theme == "pets" %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Playful ukulele</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/pets-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% else %}
      <div class="site-theme-audio">
        <span class="site-theme-audio__label">Site theme — Celtic ambient</span>
        <audio class="site-theme-audio__player" src="/star-rangers/audio/celtic-theme.wav" controls loop preload="none">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% endif %}
      <p>
        <span>{{ site.name }}</span> — Interactive Fiction.
        Copyright © {{ build.copyrightYears }} Dermot R. Cochran.
        Released under the <a href="/star-rangers/#license" rel="license">CC BY-NC-ND 4.0</a> licence.
      </p>
    </div>
  </footer>

  <script src="/star-rangers/js/pov.js?v={{ build.assetVersion }}" defer></script>
  <script src="/star-rangers/js/search.js?v={{ build.assetVersion }}" defer></script>
</body>
</html>
