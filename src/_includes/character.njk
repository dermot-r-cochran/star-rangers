---
layout: base.njk
comments: true
commentsCategory: characters
---
<article class="character-entry" data-character-id="{{ id }}">
  <header class="character-header{% if image %} character-header--with-image{% endif %}">
    <nav class="character-breadcrumb" aria-label="Character location" data-pagefind-ignore>
      <ol class="breadcrumb" role="list">
        <li><a href="/star-rangers/characters/">Characters</a></li>
        <li aria-current="page">{{ title }}</li>
      </ol>
    </nav>

    <div class="character-header__inner">
      <div class="character-header__text">
        <div class="character-meta-row">
          {% if species %}
          <span class="character-badge">{{ species }}</span>
          {% endif %}
          {% if role %}
          <span class="character-badge character-badge--role">{{ role }}</span>
          {% endif %}
          {% if status %}
          <span class="character-badge character-badge--status character-badge--status-{{ status | lower }}">{{ status }}</span>
          {% endif %}
        </div>

    <h1 class="character-name">{{ title }}</h1>

        {% if aliases and aliases.length %}
        <p class="character-aliases">
          Also known as:
          {% for alias in aliases %}
            <em>{{ alias }}</em>{% if not loop.last %}, {% endif %}
          {% endfor %}
        </p>
        {% endif %}

        {% if tags and tags.length %}
        <ul class="chapter-tags" aria-label="Tags" role="list">
          {% for tag in tags %}
          <li class="chapter-tag">{{ tag }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>

      {% if image %}
      <img class="character-portrait" src="/star-rangers/images/characters/{{ image }}" alt="{{ image_alt | default(title) }}" />
      {% endif %}
    </div>
  </header>

  <div class="character-body">
    {{ content | safe }}
  </div>

  {% if gallery and gallery.length %}
  <section class="character-gallery" aria-label="Gallery">
    <h2 class="character-gallery__title">Gallery</h2>
    <div class="character-gallery__grid">
      {% for item in gallery %}
      <img class="character-gallery__item" src="/star-rangers/images/characters/{{ id }}/{{ item.image }}" alt="{{ item.image_alt | default(title) }}" loading="lazy" />
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% set knownCodexEntries = collections.codex | codexByIds(known_codex | default([])) %}
  {% if knownCodexEntries.length %}
  <aside class="character-known-codex">
    <h2 class="character-known-codex__title">Known Codex Documents</h2>
    <ul class="character-known-codex__list" role="list">
      {% for entry in knownCodexEntries %}
      <li><a href="/star-rangers{{ entry.url }}">{{ entry.data.title }}</a></li>
      {% endfor %}
    </ul>
  </aside>
  {% endif %}

  <footer class="character-footer" data-pagefind-ignore>
    <a href="/star-rangers/characters/">← All Characters</a>
  </footer>
</article>
