---
layout: base.njk
comments: true
commentsCategory: lore
---
<article class="codex-entry" data-codex-category="{{ category }}">
  <header class="codex-entry__header">
    <nav class="codex-breadcrumb" aria-label="Codex location">
      <ol class="breadcrumb" role="list">
        <li><a href="/star-rangers/codex/">Codex</a></li>
        {% if category %}
        <li>{{ category | title }}</li>
        {% endif %}
        <li aria-current="page">{{ title }}</li>
      </ol>
    </nav>
    <h1 class="codex-entry__title">{{ title }}</h1>
    {% if category %}
    <p class="codex-entry__category">Category: <strong>{{ category }}</strong></p>
    {% endif %}
    {% if author or institution %}
    <p class="codex-entry__byline">
      {% if author %}Author: <strong>{{ author }}</strong>{% endif %}
      {% if author and institution %} — {% endif %}
      {% if institution %}Institution: <strong>{{ institution }}</strong>{% endif %}
    </p>
    {% endif %}
    {% if location %}
    <p class="codex-entry__byline">Physical record: <strong>{{ location }}</strong></p>
    {% endif %}
    {% if tags and tags.length %}
    <ul class="chapter-tags" aria-label="Tags" role="list">
      {% for tag in tags %}
      <li class="chapter-tag">{{ tag }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if image %}
    <img class="entry-image" src="/star-rangers/images/codex/{{ image }}" alt="{{ image_alt | default(title) }}" />
    {% endif %}
  </header>

  <div class="codex-entry__body">
    {{ content | safe }}
  </div>

  <footer class="codex-entry__footer">
    <a href="/star-rangers/codex/">← Back to Codex</a>
  </footer>
</article>
